{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/Images/(.*)",
      "destination": "/Images/$1"
    },
    {
      "source": "/Videos/(.*)",
      "destination": "/Videos/$1"
    },
    {
      "source": "/Font/(.*)",
      "destination": "/Font/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
